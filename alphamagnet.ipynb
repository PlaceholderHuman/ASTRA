#This is the code for n dipoles
import numpy as np
import matplotlib.pyplot as plt
import math
import re
import copy
n = 8
#8 slices minus the one big runout section is typical
#n is to control the number of slices in the alpha mag
xexport = []
zexport = []
#these are the individual points of each scaled final rotated block
g = 10.375*12
#enter gradient in G/cm above
#currently set to scaling factor times 12 amps
#1 T/m = 100 G/cm
momenty = 2.2925
#momentum in the central path of the dipole. This momentum corresponds to 0.917c speed in the middle pathway of the dipole. 
#2MeV you get total energy then find relativeness and find momentum
a = math.sqrt((5.867*math.pow(10,-4)*g/momenty))*100
#a is a main scaling factor applied to the dipole block coordinates
#a is listed in the dipole paper
#division of 100 is for conversion into meters for astra
total = []

def rotate_points(points, angle_deg):
    theta = np.radians(angle_deg)
    rotation_matrix = np.array([
        [np.cos(theta), -np.sin(theta)],
        [np.sin(theta),  np.cos(theta)]
    ])
    return points @ rotation_matrix.T
#rotation matrix to rotate set of points by 40.71 degrees
#changed from 1.89 to 1.965 to account for 16mm gap in a central beam scaling
#the runout section starts at 1.68 and ends at 1.965
#divide 0 - 1.68 into n slices and then create the runout region separate
h = 0
spacing = 1.68/n
complete = []
#hold the squares in the list named complete
previousy = 0
buffer = 0.0001
#prevent overlapping dipole error NON SIGNIFICANT
while h < n:
    #possible issue is that the x coordinate is all the same,
    #so it looks less like a dipole and may have consequences of letting particles
    #through that arent supposed to?
    #x from 0.01 to 0.9 probably change later to fit dipole shape better
    section = []
    if h ==0:
        section.append([0.9, previousy+spacing])
        section.append([0.01, previousy+spacing])
        section.append([0.01, previousy])
        section.append([0.9, previousy])
        section.append([0.9, previousy+spacing])
        #only first section dont apply buffer to 0 to become 0.001
    else:
        section.append([0.9, previousy+spacing])
        section.append([0.01, previousy+spacing])
        section.append([0.01, previousy+buffer])
        section.append([0.9, previousy+buffer])
        section.append([0.9, previousy+spacing])
        #apply buffer
    complete.append(section)
    section = []
    previousy = previousy + spacing
    h += 1

#runout section below
section.append([0.7, 1.965])
section.append([0, 1.965])
section.append([0, 1.68])
section.append([0.7, 1.68])
section.append([0.7, 1.965])
complete.append(section)
plt.figure(figsize=(6,6))
y = 0
while y<2:
    i = 0
    while i < n+1:
        square = copy.deepcopy(complete[i])
        q = 0
        while q < 5:
            square[q][0] = square[q][0]/a
            square[q][1] = (square[q][1]/a)
            q+=1
        #above is the scaling factor a usage

        if y ==1:
            #make the flipped left half of the dipole
            z = 0
            while z < 5:
                square[z][0] =  -square[z][0]
                z+=1

        square = np.array(square)

        rotated_square = rotate_points(square, 40.71)
        # Plot the original and rotated squares

        #SHIFT EVERYTHING BELOW
        #tiny shift used so that simulation will not immediately starrt in dipole block
        w = 0
        while w < 5:
                square[w][1] =  square[w][1] + 0.01
                #visual shift
                rotated_square[w][1] =  rotated_square[w][1] + 0.01
                #real shift must shift after rotation
                xexport.append(rotated_square[w][0])
                zexport.append(rotated_square[w][1])
                w+=1

        total.append(rotated_square[2])
        total.append(rotated_square[3])
        total.append(rotated_square[1])
        total.append(rotated_square[0])
        #add coords
        plt.plot(square[:, 0], square[:, 1], 'b-', label='Original Square')
        plt.plot(rotated_square[:, 0], rotated_square[:, 1], 'r--', label='Rotated 40°')
        plt.gca().set_aspect('equal')
        plt.axhline(0, color='gray', linewidth=0.5)
        plt.axvline(0, color='gray', linewidth=0.5)
        i+=1
    y+=1
print('xcoordinates of the alpha magnet', xexport)
print('zcoordinates of the alpha magnet', zexport)
plot = plt.scatter(xexport, zexport, color='red', label='Rotated Points')
    
plt.title('Dipoles Rotated 40°')
plt.grid(True)
plt.show()
b = 1
c = 0
z = 0
text = []
while b < (n+2):
    text.append("D_Type("+str(b)+") = 'hor'")
    #text.append("D1("+str(b)+") = ("+str(total[c]).strip("[]").replace(" ", "0,")+"0)")
    text.append("D1("+str(b)+") = ("+re.sub(r"\s+","0,", str(total[c]).strip("[]").rstrip())+"0)")
    c+=1
    text.append("D2("+str(b)+") = ("+re.sub(r"\s+","0,", str(total[c]).strip("[]").rstrip())+"0)")
    c+=1
    text.append("D3("+str(b)+") = ("+re.sub(r"\s+","0,", str(total[c]).strip("[]").rstrip())+"0)")
    c+=1
    text.append("D4("+str(b)+") = ("+re.sub(r"\s+","0,", str(total[c]).strip("[]").rstrip())+"0)")
    c+=1
    B = (((b)-1/2)*g*spacing/a)/100
    #B MUST BE IN TESLAS SO DIVIDE BY 100
    if b == (n+1):
        B = (1.68)/a*g/100
        #runout region
    p = 1.704*math.pow(10,-3)*momenty/B
    
    text.append("D_strength("+str(b)+") = -"+ str(B))
    text.append("D_Gap(1,"+str(b)+") = 0.00")
    text.append("D_Gap(2,"+str(b)+") = 0.00")
    b+=1
while b < 2*(n+1)+1:
    text.append("D_Type("+str(b)+") = 'hor'")
    #text.append("D1("+str(b)+") = ("+str(total[c]).strip("[]").replace(" ", "0,")+"0)")
    text.append("D3("+str(b)+") = ("+re.sub(r"\s+","0,", str(total[c]).strip("[]").rstrip())+"0)")
    c+=1
    text.append("D4("+str(b)+") = ("+re.sub(r"\s+","0,", str(total[c]).strip("[]").rstrip().lstrip())+"0)")
    c+=1
    text.append("D1("+str(b)+") = ("+re.sub(r"\s+","0,", str(total[c]).strip("[]").rstrip())+"0)")
    c+=1
    text.append("D2("+str(b)+") = ("+re.sub(r"\s+","0,", str(total[c]).strip("[]").rstrip().lstrip())+"0)")
    c+=1
    #SWITCHED ENTRY EXIT FACES
    B = (((b-(n+1))-1/2)*g*spacing/a)/100
    #B MUST BE IN TESLAS/METERS SO DIVIDE BY 100
    if b == 2*(n+1):
        B = (1.68)/a*g/100
    p = 0.00170469*momenty/B

    text.append("D_strength("+str(b)+") = -"+ str(B))
    text.append("D_Gap(1,"+str(b)+") = 0.00")
    text.append("D_Gap(2,"+str(b)+") = 0.00")
    b+=1
for i in text:
    print(i)
